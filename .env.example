MAIL_ADDRESS=
MAIL_PASSWORD=

# Enter the IMAP settings supplied by your email provider.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true

# Enter the SMTP settings supplied by your email provider.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true

MCP_HOST=127.0.0.1
MCP_PORT=3000

MAX_EMAIL_SIZE_BYTES=10000000
MAX_EMAIL_BODY_CHARACTERS=30000
MAX_SEARCH_RESULTS=20

# Write actions stay unavailable until explicitly enabled.
WRITE_ACTIONS_ENABLED=false
CONFIRMATION_SIGNING_SECRET=
CONFIRMATION_TTL_SECONDS=300
MAX_SEND_RECIPIENTS=20
MAX_SEND_BODY_CHARACTERS=100000

# local: loopback access with a synthetic local principal
# oauth: required for any direct public deployment; not needed for a local Secure MCP Tunnel setup
AUTH_MODE=local
APP_BASE_URL=http://127.0.0.1:3000
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_JWKS_URI=
OAUTH_AUTHORIZATION_SERVER=
OAUTH_ALLOWED_USERS=

# Required for production replay protection, global rate limits and audits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
AUDIT_RETENTION_SECONDS=2592000

# OpenAI Secure MCP Tunnel. Keep both values out of Git.
# Create the runtime API key and tunnel in OpenAI Platform tunnel settings.
CONTROL_PLANE_API_KEY=
CONTROL_PLANE_TUNNEL_ID=

# Optional paths for a Raspberry Pi/systemd installation if Node or tunnel-client
# are not installed in the service PATH.
# NODE_BIN=/usr/bin/node
# NPM_BIN=/usr/bin/npm
# TUNNEL_CLIENT_BIN=/usr/local/bin/tunnel-client
